# Server
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/cyberwatch-kenya

# JWT Secret (change this to a long random string in production)
JWT_SECRET=cyberwatch_super_secret_key_change_this_in_production

# Email Config (use Gmail or any SMTP provider)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=CyberWatch Kenya <your-email@gmail.com>

# Admin Setup (first-time admin account)
ADMIN_EMAIL=admin@cyberwatchkenya.com
ADMIN_PASSWORD=Admin@123456
